#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

cd "$repo_root"

# Keep this hook product-local and non-mutating. CH-0012 owns future packaging
# and packaged-surface alignment checks.
echo "[1/1] Running lantern test suite..."
PYTEST_DISABLE_PLUGIN_AUTOLOAD=1 python -m pytest tests/ -q

echo "✓ All pre-commit checks passed"
